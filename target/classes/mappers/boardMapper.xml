<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.board.mappers.board">

	<!-- 거래처 목록 -->
	<select id="list" resultType="com.board.domain.BoardVO">
		select
			busi_num, short_, custom, ceo, charge_person
		from tbl_custom
	</select>

	<!-- 거래처 등록 -->
	<insert id="write" parameterType="com.board.domain.BoardVO">
		insert into
			tbl_custom(busi_num, short_, custom, ceo, charge_person)
		values(#{busi_num}, #{short_}, #{custom}, #{ceo}, #{charge_person})
	</insert>

	<!-- 거래처 조회 -->
	<select id="view" parameterType="string" resultType="com.board.domain.BoardVO">
		select
			*
		from
			tbl_custom
		where
			busi_num = #{busi_num}   
	</select>

	<!-- 거래처 수정 -->
	<update id="modify" parameterType="com.board.domain.BoardVO">
		update tbl_custom
			set
				short_ = #{short_},
				custom = #{custom},
				ceo = #{ceo},
				charge_person = #{charge_person}
			where 
				busi_num = #{busi_num} 
	</update>

	<!-- 게시물 삭제 -->
	<delete id="delete" parameterType="string">
		delete
			from tbl_custom
		where 
			busi_num = #{busi_num}
	</delete>

	<!-- 게시물 총 갯수 -->
	<!-- <select id="count" resultType="int">
		select count(bno) from tbl_custom
	</select> -->

	<!-- 게시물 목록 + 페이징 -->
	<!-- <select id="listPage" parameterType="hashMap" resultType="com.board.domain.BoardVO">
		select
		bno, title, writer, regDate, viewCnt
		from tbl_custom
		order by bno desc
		limit #{displayPost}, #{postNum}
	</select> -->
</mapper>